# .env.example — Pizza3.14
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# -------------------------------------------------------
# Database (Supabase free tier PostgreSQL)
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# -------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/pizza314

# -------------------------------------------------------
# Auth secret — used to sign demo passphrase cookies
# Generate with: openssl rand -hex 32
# -------------------------------------------------------
AUTH_SECRET=replace_with_32_byte_hex_secret

# -------------------------------------------------------
# Demo passphrases for kitchen and admin pages
# Change these before sharing any demo URL publicly
# -------------------------------------------------------
KITCHEN_PASSPHRASE=kitchen_demo
ADMIN_PASSPHRASE=admin_demo

# -------------------------------------------------------
# App URL (used for absolute URLs in emails, OG tags etc.)
# -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
