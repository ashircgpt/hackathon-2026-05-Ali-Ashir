# .env.example — Pizza3.14
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# -------------------------------------------------------
# Database (Supabase free tier PostgreSQL)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" format with pooler (Transaction mode, port 5432)
# -------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/postgres

# -------------------------------------------------------
# Auth secret — used to sign demo passphrase cookies
# Generate with: openssl rand -hex 32
# -------------------------------------------------------
AUTH_SECRET=replace_with_32_byte_hex_from_openssl_rand_hex_32

# -------------------------------------------------------
# Demo passphrases for kitchen and admin pages
# Change these before sharing any demo URL publicly
# -------------------------------------------------------
KITCHEN_PASSPHRASE=kitchen_demo
ADMIN_PASSPHRASE=admin_demo

# -------------------------------------------------------
# App URL (used for Socket.io, OG tags etc.)
# -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------
# PostHog — product analytics (optional, free tier)
# Get from: app.posthog.com → Project Settings → Project API key
# Leave blank to disable analytics entirely
# -------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -------------------------------------------------------
# Sentry — error monitoring (optional, free tier)
# Get from: sentry.io → Project → Settings → Client Keys (DSN)
# Leave blank to disable error reporting entirely
# -------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
